{
  "rules": {
    "deviceIds": {
      "civiloff": {
        ".read": true,
        "$deviceId": {
          ".write": "newData.child('deviceKey').val() === $deviceId",
          ".validate": "newData.hasChildren(['deviceKey', 'firstSeenAt', 'lastSeenAt'])"
        }
      }
    },
    "presence": {
      ".read": false,
      ".write": false
    }
  }
}
